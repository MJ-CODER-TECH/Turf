# ============================================
# TURFZONE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ── SERVER ──────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── MONGODB ─────────────────────────────────
MONGO_URI=mongodb://localhost:27017/TurfZone
# Production: MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/turfzone

# ── JWT ─────────────────────────────────────
JWT_SECRET=sdfjsdkfjdijfkdmfkjskdfm
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=jshdfjdsjfhnfjsdnj
JWT_REFRESH_EXPIRE=30d

# ── SMTP (Email) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=beldarmozzimjamal@gmail.com
SMTP_PASS=uveiatfacqumszwh
EMAIL_FROM=TurfZone <beldarmozzimjamal@gmail.com>
EMAIL_FROM_NAME=TurfZone

# ── TWILIO (SMS) ────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# OR use WhatsApp: TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── RAZORPAY (Payments) ─────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── CLOUDINARY (Image Upload) ───────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── REDIS (Caching/Sessions) ─────────────────
REDIS_URL=redis://localhost:6379
# Production: REDIS_URL=redis://:password@host:6379

# ── RATE LIMITING ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── FRONTEND URL (CORS) ──────────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_PROD=https://turfzone.in

# ── OTP SETTINGS ───────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# ── BOOKING SETTINGS ────────────────────────
BOOKING_CANCELLATION_HOURS=4
SLOT_DURATION_MINUTES=60

# ── ADMIN ───────────────────────────────────
ADMIN_EMAIL=beldarmozzimjamal@gmail.com
ADMIN_PHONE=9146328932
